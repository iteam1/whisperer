{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "rootDir": "src",
        "outDir": "out",
        "sourceMap": true,
        "types": ["vscode", "node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "out"]
}
